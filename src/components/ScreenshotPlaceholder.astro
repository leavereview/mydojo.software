---
interface Props {
  caption: string;
  alt?: string;
}
const { caption, alt = caption } = Astro.props;
---

<figure class="screenshot-placeholder my-8">
  <div class="bg-gray-100 border-2 border-dashed border-gray-300 rounded-lg p-8 flex flex-col items-center justify-center min-h-48">
    <svg class="w-12 h-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <p class="text-gray-500 text-sm text-center">{alt}</p>
    <span class="mt-2 text-xs text-gray-400 uppercase tracking-wide">Screenshot Coming Soon</span>
  </div>
  <figcaption class="text-center text-sm text-gray-600 mt-2 italic">{caption}</figcaption>
</figure>
